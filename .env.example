APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

# Redis Configuration (Feature 6 - Performance Optimization)
# To enable Redis caching, add a Redis service in Railway and set:
#   CACHE_DRIVER=redis
#   REDIS_HOST=<your-redis-host>
#   REDIS_PASSWORD=<your-redis-password>
#   REDIS_PORT=6379
#   REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

# Pusher Configuration (Feature 4 - Real-time Notifications)
# To enable real-time notifications, create a Pusher account and set:
#   BROADCAST_DRIVER=pusher
#   PUSHER_APP_ID=<your-app-id>
#   PUSHER_APP_KEY=<your-app-key>
#   PUSHER_APP_SECRET=<your-app-secret>
#   PUSHER_APP_CLUSTER=<your-cluster>
# Default: BROADCAST_DRIVER=log (notifications still saved to database)

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ===== Spatie Activity Log =====
ACTIVITY_LOGGER_ENABLED=true

# ===== Spatie Backup =====
BACKUP_ARCHIVE_PASSWORD=

# ===== WhatsApp / Twilio Integration =====
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_ENABLED=false

# ===== PWA Configuration =====
PWA_APP_NAME=madrasati
PWA_APP_THEME_COLOR=#4e73df
PWA_APP_BACKGROUND_COLOR=#ffffff

# ===== Auto Promotion Engine Criteria =====
PROMOTION_MIN_AVERAGE=50
PROMOTION_MAX_FAILED_SUBJECTS=2
PROMOTION_AUTO_NOTIFY_PARENTS=true

# ===== Stripe (Payment Gateway) =====
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ===== Laravel Horizon =====
HORIZON_PREFIX=horizon:
HORIZON_EMAIL=

# ===== Laravel Telescope =====
TELESCOPE_ENABLED=false

# ===== Spatie Permission =====
# (no env vars needed)

# ===== Spatie MediaLibrary =====
MEDIA_DISK=public
